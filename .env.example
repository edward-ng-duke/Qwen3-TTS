# Copy to .env for local development. Keep real secrets out of git.

PORT=4967
WEB_PORT=4968

# Dev-only ports (Makefile `dev`/`api-dev`/`web-dev`). Independent from PORT/WEB_PORT
# so `make deploy` (container on 4967) and `make dev` (local backend on 4970 + vite
# on 4971) can run side-by-side.
DEV_PORT=4970
DEV_WEB_PORT=4971

MODEL_VARIANT=customvoice

AUTH_ENABLED=auto
VITE_AUTH_REQUIRED=true
MONGO_ENABLED=true
MONGO_URL=mongodb://10.0.0.93:27017
DB_NAME=conference_ws
MONGO_TIMEOUT_MS=5000
MONGO_MAX_POOL_SIZE=10

# Raw JWT secret is not kept in .env. make dev/deploy read this file.
JWT_SECRET_FILE=auth_doc/jwt
JWT_EXPIRE_DAYS=7

ES_AUTH_ENABLED=true
ES_AUTH_URL=http://10.0.0.33:9201
ES_USER_INDEX=mygpt_user
ES_AUTH_TIMEOUT=5
ES_TOKEN_COOKIE_NAME=token2
ES_TOKEN_HEADER_NAME=X-token-2
